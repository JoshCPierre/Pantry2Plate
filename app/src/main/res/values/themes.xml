<resources>

    <style name="Theme.Pantry2Plate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="android:windowBackground">@color/cream_bg</item>
        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:statusBarColor">@color/primary_green_dark</item>
        <item name="buttonStyle">@style/PantryButton</item>
        <item name="android:windowBackground">@color/cream_bg</item>
    </style>

    <style name="PantryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="backgroundTint">@color/primary_green</item>
        <item name="shapeAppearanceOverlay">@style/PantryButtonShape</item>
    </style>

    <style name="PantryButtonShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="PantryTitleText">
        <item name="android:fontFamily">@font/single_day</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="PantryScreenTitle">
        <item name="android:fontFamily">@font/single_day</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

</resources>