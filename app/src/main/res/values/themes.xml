<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Pantry2Plate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color (Now Beige) -->
        <item name="colorPrimary">@color/primary_beige</item>
        <item name="colorPrimaryVariant">@color/primary_dark_beige</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary_brown</item>
        <item name="colorSecondaryVariant">@color/secondary_brown</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background and Surface -->
        <item name="android:windowBackground">@color/background_beige</item>
        <item name="colorSurface">@color/surface_cream</item>
        <item name="colorOnSurface">@color/text_brown</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Customize your theme here. -->
        <item name="android:textColorPrimary">@color/text_brown</item>
    </style>
</resources>